rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole(spaceId) {
      return get(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid)).data.role;
    }

    function isSpaceMember(spaceId) {
      return exists(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid));
    }

    function isMonitor(spaceId) {
      return isSpaceMember(spaceId) && getUserRole(spaceId) == 'monitor';
    }

    function isAssistantMonitor(spaceId) {
      return isSpaceMember(spaceId) && getUserRole(spaceId) == 'assistant_monitor';
    }

    // USERS
    match /users/{userId} {
      allow create: if isUser(userId);
      allow read, update: if isUser(userId);
      allow delete: if false;
      
      match /memberships/{spaceId} {
        allow read, write: if isUser(userId);
      }
    }

    // SPACES
    match /spaces/{spaceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Adjust if space creation is restricted
      allow update, delete: if isMonitor(spaceId);

      match /members/{memberId} {
        allow read: if isSpaceMember(spaceId);
        allow create, update, delete: if isMonitor(spaceId) || isAssistantMonitor(spaceId);
      }

      match /courses/{courseId} {
        allow read: if isSpaceMember(spaceId);
        allow write: if isMonitor(spaceId) || isAssistantMonitor(spaceId);
      }

      match /posts/{postId} {
        allow read: if isSpaceMember(spaceId);
        allow create: if isSpaceMember(spaceId);
        allow update, delete: if isMonitor(spaceId) || request.auth.uid == resource.data.authorId;
      }

      match /attendanceSessions/{sessionId} {
        allow read: if isSpaceMember(spaceId);
        allow create, update: if isMonitor(spaceId) || isAssistantMonitor(spaceId);
        allow delete: if false;
      }

      match /attendanceRecords/{recordId} {
        allow read: if isSpaceMember(spaceId) && (
          resource.data.studentId == request.auth.uid || isMonitor(spaceId)
        );
        allow create: if isSpaceMember(spaceId) 
          && request.auth.uid == request.resource.data.studentId
          && getAfter(/databases/$(database)/documents/spaces/$(spaceId)/attendanceSessions/$(request.resource.data.sessionId)).data.codeExpiresAt > request.time;
        allow update: if isMonitor(spaceId);
        allow delete: if false;
      }

      match /materials/{materialId} {
        allow read: if isSpaceMember(spaceId);
        allow create: if isMonitor(spaceId) || isAssistantMonitor(spaceId);
        allow update, delete: if isMonitor(spaceId);
      }
    }

    // NOTIFICATIONS
    match /notifications/{userId} {
      allow read, update: if isUser(userId);
      allow create: if isAuthenticated(); // Tighten to admin/service account in production
      allow delete: if false;
    }

    // PERSONAL COURSES — owner-only access
    match /personalCourses/{courseId} {
      allow read: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow delete: if false; // Archive only — no hard deletes
    }
  }
}
