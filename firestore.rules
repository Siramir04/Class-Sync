rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserRole(spaceId) {
      return get(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid)).data.role;
    }
    
    function isSpaceMember(spaceId) {
      return exists(/databases/$(database)/documents/spaces/$(spaceId)/members/$(request.auth.uid));
    }
    
    function isMonitor(spaceId) {
      return isSpaceMember(spaceId) && getUserRole(spaceId) in ['monitor', 'assistant_monitor', 'lecturer'];
    }
    
    function isAssistantMonitor(spaceId) {
      return isSpaceMember(spaceId) && getUserRole(spaceId) == 'assistant_monitor';
    }
    
    function isLecturer(spaceId) {
      return isSpaceMember(spaceId) && getUserRole(spaceId) == 'lecturer';
    }
    
    function isAdmin(spaceId) {
      return isSpaceMember(spaceId) && getUserRole(spaceId) == 'monitor';
    }
    
    // Check if an attendance session is currently open
    // Actual path: spaces/{spaceId}/courses/{courseId}/attendance/{sessionId}
    function isSessionOpen(spaceId, courseId, sessionId) {
      return get(/databases/$(database)/documents/spaces/$(spaceId)/courses/$(courseId)/attendance/$(sessionId)).data.isOpen == true;
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if isUser(userId);
      
      // Memberships subcollection: user can read their own, 
      // space monitors can read members of their space (for management)
      match /memberships/{spaceId} {
        allow read: if isUser(userId) || isMonitor(spaceId);
        allow write: if isUser(userId); // Only the user writes their own memberships
      }
    }
    
    // ============================================
    // SPACES COLLECTION
    // ============================================
    
    match /spaces/{spaceId} {
      // Anyone authenticated can read space metadata (needed for joining)
      allow read: if isAuthenticated();
      
      // Only monitors can update space settings
      allow update: if isAdmin(spaceId);
      allow delete: if isAdmin(spaceId);
      
      // Members subcollection
      match /members/{memberId} {
        // Members can read other members (for contact lists, attendance)
        allow read: if isSpaceMember(spaceId);
        
        // Only monitors can add/remove/change roles
        allow create, update, delete: if isMonitor(spaceId);
        
        // Users can write their OWN membership doc on join (if invitation code valid)
        // This is handled client-side with transaction — rules allow if not existing
        allow create: if isUser(memberId) && !exists(/databases/$(database)/documents/spaces/$(spaceId)/members/$(memberId));
      }
      
      // Courses subcollection
      match /courses/{courseId} {
        allow read: if isSpaceMember(spaceId);
        allow write: if isMonitor(spaceId);
        
        // ============================================
        // ATTENDANCE SESSIONS
        // Actual path: spaces/{spaceId}/courses/{courseId}/attendance/{sessionId}
        // ============================================
        match /attendance/{sessionId} {
          allow read: if isAuthenticated() && isSpaceMember(spaceId);
          
          // Only monitors/assistant monitors can start and manage sessions
          allow create, update: if isAuthenticated() && (
            isMonitor(spaceId) || isAssistantMonitor(spaceId)
          );
          
          // Never delete attendance sessions — audit trail
          allow delete: if false;
          
          // ============================================
          // ATTENDANCE RECORDS
          // Actual path: spaces/{spaceId}/courses/{courseId}/attendance/{sessionId}/records/{uid}
          // ============================================
          match /records/{uid} {
            allow read: if isAuthenticated() && (
              isMonitor(spaceId) ||
              request.auth.uid == uid
            );
            
            // CRITICAL: student can only mark their OWN attendance
            // AND only in an open session
            allow create: if isAuthenticated()
              && request.auth.uid == uid
              && isSpaceMember(spaceId)
              && isSessionOpen(spaceId, courseId, sessionId);
            
            // Monitors can also create records (e.g. marking absent students on close)
            allow create: if isAuthenticated() && isMonitor(spaceId);
            
            // Only monitors can update records (e.g. verify flagged entries)
            allow update: if isAuthenticated() && isMonitor(spaceId);
            
            // Never delete attendance records — audit trail
            allow delete: if false;
          }
        }
        
        // Course members subcollection
        match /members/{memberId} {
          allow read: if isSpaceMember(spaceId);
          allow write: if isMonitor(spaceId);
          allow create: if isUser(memberId) && isSpaceMember(spaceId);
        }
        
        // Course settings subcollection
        match /settings/{settingId} {
          allow read: if isSpaceMember(spaceId);
          allow write: if isMonitor(spaceId);
        }
      }
      
      // Posts subcollection
      match /posts/{postId} {
        allow read: if isSpaceMember(spaceId);
        allow create: if isSpaceMember(spaceId); // Any member can post (adjust if needed)
        allow update, delete: if isMonitor(spaceId) || request.auth.uid == resource.data.authorId;
      }
    }
    
    // ============================================
    // NOTIFICATIONS
    // ============================================
    
    match /notifications/{notificationId} {
      // User can only read their own notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false; // Server-only via Cloud Functions or admin SDK
    }
    
    // Notification subcollection pattern (if used)
    match /notifications/{uid}/items/{notificationId} {
      allow read, update: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated();
      allow delete: if false;
    }
  }
}
